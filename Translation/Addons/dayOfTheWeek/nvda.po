#: addon\globalPlugins\dayOfTheWeek.py:43
msgid "You can select a day with the vertical arrows"
msgstr "使用上下光标选择日期"

#: addon\globalPlugins\dayOfTheWeek.py:44
msgid "Select a day"
msgstr "选择日"

#: addon\globalPlugins\dayOfTheWeek.py:47
msgid "You can select a month with the vertical arrows"
msgstr "使用上下光标选择月份"

#: addon\globalPlugins\dayOfTheWeek.py:48
msgid "Select a month"
msgstr "选择月"

#: addon\globalPlugins\dayOfTheWeek.py:51
msgid "You can select a year with the vertical arrows"
msgstr "使用上下光标选择年份"

#: addon\globalPlugins\dayOfTheWeek.py:52
msgid "Select a year"
msgstr "选择年"

#: addon\globalPlugins\dayOfTheWeek.py:99
#: addon\globalPlugins\dayOfTheWeek.py:483
msgid "Get the day of the week"
msgstr "星期查询"

#: addon\globalPlugins\dayOfTheWeek.py:102
msgid "Type or select a date"
msgstr "输入或选择一个日期"

#: addon\globalPlugins\dayOfTheWeek.py:138
msgid "Your day"
msgstr "这天是"

#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: addon\globalPlugins\dayOfTheWeek.py:148 buildVars.py:20
msgid "Day of the week"
msgstr "星期查询"

#: addon\globalPlugins\dayOfTheWeek.py:150
msgid "Short"
msgstr "简略"

#: addon\globalPlugins\dayOfTheWeek.py:151
msgid "Long"
msgstr "详细"

#: addon\globalPlugins\dayOfTheWeek.py:152
msgid "Off"
msgstr "关闭"

#: addon\globalPlugins\dayOfTheWeek.py:156
msgid "En&able the accessibility of the date selector:"
msgstr "启用日期选择器的无障碍访问(&A)"

#: addon\globalPlugins\dayOfTheWeek.py:157
msgid "Level of the announces of &labels:"
msgstr "标签播报级别(&L)"

#: addon\globalPlugins\dayOfTheWeek.py:159
msgid "Enable announcements of the current date field value only, when moving &vertically:"
msgstr "垂直移动时仅读出当前日期字段的值(&V)"

#: addon\globalPlugins\dayOfTheWeek.py:491
msgid "Day of the &week..."
msgstr "查询星期(&W)..."

#: addon\globalPlugins\dayOfTheWeek.py:492
msgid "Search a day in the calendar"
msgstr "在日历中搜索一天"

#: addon\globalPlugins\dayOfTheWeek.py:510
msgid "Allows you to find the day of the week corresponding to a chosen date."
msgstr "允许您查看所选日期是星期几。"

#: addon\globalPlugins\dayOfTheWeek.py:517
#, python-brace-format
msgid "Allows you to open the {0} add-on settings dialog."
msgstr "允许您打开{0}插件设置对话框。"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:23
msgid "With this add-on, you'll be able to find the day of the week corresponding to a chosen date."
msgstr "借助此插件，您可以找到与所选日期对应的星期。"

