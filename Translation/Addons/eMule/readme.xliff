    <unit id="982812ea-e61e-4b5d-92dd-cce1bc7a4d2b">
      <notes>
        <note appliesTo="source">line: 34</note>
        <note appliesTo="source">prefix: *	</note>
      </notes>
      <segment state="final">
        <source>nvda+control+1-0: Reads the first 10 columns.</source>
        <target>nvda+control+1到0： 朗读前十列。</target>
      </segment>
    </unit>
    <unit id="6a8a6b76-7f13-4cae-bc6a-fe2c8288e732">
      <notes>
        <note appliesTo="source">line: 35</note>
        <note appliesTo="source">prefix: *	</note>
      </notes>
      <segment state="final">
        <source>nvda+shift+1-0: Reads columns 11 to 20.</source>
        <target>nvda+shift+1到0： 朗读第11到20列。</target>
      </segment>
    </unit>
    <unit id="dbd58388-f7ca-4ed7-a2f2-706a65cdde08">
      <notes>
        <note appliesTo="source">line: 36</note>
        <note appliesTo="source">prefix: *	</note>
      </notes>
      <segment state="final">
        <source>nvda+shift+C: Copies the contents of the last read column to the clipboard.</source>
        <target>nvda+shift+C： 拷贝最后一次朗读的那一列的内容到剪贴板。</target>
      </segment>
    </unit>
    <unit id="e82799c5-5f9e-4766-821b-e4d62e099c9b">
