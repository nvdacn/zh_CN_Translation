#. Translators: This is the label for the AudioScreen settings panel.
#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: addon\globalPlugins\objPad.py:40 buildVars.py:21
msgid "ObjPad"
msgstr "简易导航器"

#. Translators: Label for the list of browse mode navigation element types in ObjPad settings.
#: addon\globalPlugins\objPad.py:50
msgid "&Browse mode navigation elements:"
msgstr "浏览模式导航元素(&B)："

#. Translators: input help mode message for ObjPad toggle command.
#: addon\globalPlugins\objPad.py:82
msgid "Toggles ObjPad mode between normal, object nav and scan modes"
msgstr "简易导航切换（在正常模式、对象导航模式、网页模式和扫描模式之间切换）"

#. Translators: one of the object arrow modes.
#: addon\globalPlugins\objPad.py:90
msgid "Object nav mode"
msgstr "对象导航模式"

#. Translators: one of the object arrow modes.
#: addon\globalPlugins\objPad.py:94
msgid "Browse mode"
msgstr "浏览模式"

#. Translators: one of the object arrow modes.
#: addon\globalPlugins\objPad.py:98
msgid "Scan mode"
msgstr "扫描模式"

#. Translators: one of the object arrow modes.
#: addon\globalPlugins\objPad.py:102
msgid "Normal mode"
msgstr "正常模式"

#: addon\globalPlugins\objPad.py:128
msgid "default"
msgstr "默认"

#: addon\globalPlugins\objPad.py:129
msgid "headings"
msgstr "标题"

#: addon\globalPlugins\objPad.py:130
msgid "tables"
msgstr "表格"

#: addon\globalPlugins\objPad.py:131
msgid "links"
msgstr "链接"

#: addon\globalPlugins\objPad.py:132
msgid "form fields"
msgstr "表单字段"

#: addon\globalPlugins\objPad.py:133
msgid "lists"
msgstr "列表"

#: addon\globalPlugins\objPad.py:134
msgid "frames"
msgstr "框架"

#: addon\globalPlugins\objPad.py:136
msgid "landmarks"
msgstr "路标"

#: addon\globalPlugins\objPad.py:137
msgid "embedded objects"
msgstr "嵌入式对象"

#: addon\globalPlugins\objPad.py:138
msgid "text paragraphs"
msgstr "文本段落"

#. Translators: a message when there is no next object when navigating
#: addon\globalPlugins\objPad.py:245
msgid "No next"
msgstr "没有下一项"

#. Translators: a message when there is no previous object when navigating
#: addon\globalPlugins\objPad.py:286
msgid "No previous"
msgstr "没有上一项"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "Perform various object commands by pressing a single key, including navigation and more"
msgstr "一键执行各种对象快捷键，包括导航等"

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid "* In NVDA 2026.2 running on non-touch devices or portable versions, added ObjPad settings (NVDA settings screen) to configure browse mode navigation elements."
msgstr ""

